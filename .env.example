# required
GEINS_API_URL= # url to geins api
AUTH_SECRET= # generated secret

# optional
GEINS_DEBUG= # true or false
BASE_URL= # url to your application
AUTH_PATH= # path to your auth server function

# Brand override for local dev (geins or litium)
NUXT_PUBLIC_BRAND_OVERRIDE=

# TEMP hotfix (STU-216) — shared secret for sales-portal config-refresh webhook.
# Remove once BE handles config-refresh natively (STU-217).
SALES_PORTAL_WEBHOOK_SECRET= # your shared secret here
