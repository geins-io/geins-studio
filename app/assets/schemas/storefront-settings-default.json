{
  "baseSettings": {
    "label": "Base settings",
    "sections": [
      {
        "key": "storefrontMode",
        "title": "Storefront mode",
        "description": "Choose if you want your storefront to enable direct purchases of your products, or work as a product catalogue",
        "fields": [
          {
            "key": "storefrontMode",
            "type": "radio-cards",
            "label": "Storefront mode",
            "default": "commerce",
            "options": [
              {
                "value": "commerce",
                "label": "Commerce",
                "description": "Enables visitors to purchase your products directly in the page. With buy buttons and checkout flow.",
                "icon": "ShoppingCart"
              },
              {
                "value": "catalogue",
                "label": "Catalogue",
                "description": "Shows all your products, but without commerce functionality such as buy buttons and checkout.",
                "icon": "BookOpenText"
              }
            ]
          }
        ]
      },
      {
        "key": "defaultSettings",
        "title": "Default settings",
        "description": "Base settings used globally unless otherwise configured.",
        "fields": [
          {
            "key": "accessRequirements",
            "type": "group",
            "label": "Access requirements",
            "description": "Define which actions require login. These settings are global and may be overridden by roles or permissions.",
            "icon": "UserLock",
            "default": true,
            "children": [
              {
                "key": "accessRequirements.priceVisibility",
                "type": "boolean",
                "label": "Price visibility",
                "description": "Prices are visible only to logged-in users.",
                "icon": "DollarSign",
                "default": true
              },
              {
                "key": "accessRequirements.orderPlacement",
                "type": "boolean",
                "label": "Order placement",
                "description": "Orders can only be placed by logged-in users.",
                "icon": "ShoppingCart",
                "default": true
              },
              {
                "key": "accessRequirements.stockStatus",
                "type": "boolean",
                "label": "Stock status",
                "description": "Products stock levels are visible only to logged-in users.",
                "icon": "ChartColumn",
                "default": false
              }
            ]
          }
        ]
      }
    ]
  },
  "layoutOptions": {
    "label": "Layout options",
    "sections": [
      {
        "key": "logotype",
        "title": "Logotype",
        "description": "Choose between rounded or square corners for interface elements.",
        "icon": "Image",
        "fields": [
          {
            "key": "logotype",
            "type": "image",
            "label": "Logotype",
            "columns": 2
          }
        ]
      },
      {
        "key": "borderRadius",
        "title": "Corner style",
        "description": "Choose between rounded or square corners for interface elements.",
        "icon": "SquareArrowUpRight",
        "fields": [
          {
            "key": "borderRadius",
            "type": "radio-cards",
            "label": "Corner style",
            "default": "0",
            "options": [
              {
                "value": "0",
                "label": "Square",
                "description": "Gives interface elements square corners.",
                "icon": "Square"
              },
              {
                "value": "0.375rem",
                "label": "Round",
                "description": "Gives interface elements rounded corners.",
                "icon": "SquareRoundCorner"
              }
            ]
          }
        ]
      },
      {
        "key": "fonts",
        "title": "Font settings",
        "description": "Choose between rounded or square corners for interface elements.",
        "icon": "FileTypeCorner",
        "fields": [
          {
            "key": "fonts.headings",
            "type": "font",
            "label": "Headings",
            "description": "Used for selected heading elements used on pages and content",
            "placeholder": "Geist (template default)",
            "default": "Hanuman",
            "columns": 2
          },
          {
            "key": "fonts.body",
            "type": "font",
            "label": "Body text",
            "description": "Applied to body text, descriptions, and supporting content.",
            "placeholder": "Geist (template default)",
            "default": "Geist",
            "columns": 2
          }
        ]
      },
      {
        "key": "themeColors",
        "title": "Theme colors",
        "description": "Set background and text colors for selected interface elements.",
        "icon": "Palette",
        "fields": [
          {
            "key": "themeColors.buttons",
            "type": "sub-section",
            "label": "Buttons",
            "description": "Set background and text colors for selected interface elements.",
            "columns": 2,
            "children": [
              {
                "key": "themeColors.buttons.general",
                "type": "sub-section",
                "label": "General buttons",
                "children": [
                  {
                    "key": "themeColors.buttons.general.background",
                    "type": "color",
                    "label": "Background",
                    "columns": 2,
                    "default": "#0E7490"
                  },
                  {
                    "key": "themeColors.buttons.general.text",
                    "type": "color",
                    "label": "Text",
                    "columns": 2,
                    "default": "#FFFFFF"
                  }
                ]
              },
              {
                "key": "themeColors.buttons.purchase",
                "type": "sub-section",
                "label": "Purchase buttons",
                "children": [
                  {
                    "key": "themeColors.buttons.purchase.background",
                    "type": "color",
                    "label": "Background",
                    "columns": 2,
                    "default": "#0E7490"
                  },
                  {
                    "key": "themeColors.buttons.purchase.text",
                    "type": "color",
                    "label": "Text",
                    "columns": 2,
                    "default": "#FFFFFF"
                  }
                ]
              }
            ]
          },
          {
            "key": "themeColors.siteBackground",
            "type": "sub-section",
            "label": "Site background",
            "description": "Set background and text colors for selected interface elements.",
            "children": [
              {
                "key": "themeColors.siteBackground.color",
                "type": "radio-cards",
                "label": "Site background",
                "default": "#ffffff",
                "options": [
                  {
                    "value": "#ffffff",
                    "label": "White",
                    "type": "color",
                    "description": "The background of your storefront will be white"
                  },
                  {
                    "value": "#FAFAFA",
                    "label": "Light gray",
                    "type": "color",
                    "description": "The background of your storefront will be light gray"
                  }
                ]
              }
            ]
          },
          {
            "key": "themeColors.navBarBackground",
            "type": "sub-section",
            "label": "Navigation bar background",
            "description": "Set background and text colors for selected interface elements.",
            "children": [
              {
                "key": "themeColors.navBarBackground.color",
                "type": "radio-cards",
                "label": "Navigation bar background",
                "default": "#F5F5F5",
                "options": [
                  {
                    "value": "#ffffff",
                    "label": "White",
                    "type": "color",
                    "description": "The background of your navigation bar will be white"
                  },
                  {
                    "value": "#F5F5F5",
                    "label": "Light gray",
                    "type": "color",
                    "description": "The background of your navigation bar will be light gray"
                  }
                ]
              }
            ]
          },
          {
            "key": "themeColors.topBar",
            "type": "sub-section",
            "label": "Site top bar",
            "description": "Set background and text colors for selected interface elements.",
            "children": [
              {
                "key": "themeColors.topBar.background",
                "type": "color",
                "label": "Background",
                "columns": 4,
                "default": "#0E7490"
              },
              {
                "key": "themeColors.topBar.text",
                "type": "color",
                "label": "Text",
                "columns": 4,
                "default": "#FFFFFF"
              }
            ]
          },
          {
            "key": "themeColors.footer",
            "type": "sub-section",
            "label": "Footer",
            "description": "Set background and text colors for selected interface elements.",
            "children": [
              {
                "key": "themeColors.footer.background",
                "type": "color",
                "label": "Background",
                "columns": 4,
                "default": "#F5F5F5"
              },
              {
                "key": "themeColors.footer.text",
                "type": "color",
                "label": "Text",
                "columns": 4,
                "default": "#0A0A0A"
              }
            ]
          }
        ]
      }
    ]
  }
}
